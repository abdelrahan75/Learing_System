@model Task_Day_2_ASP.Models.Entities.Department
@{
    ViewData["Title"] = "Edit Department";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#f59e0b,#d97706)">
    <h1><i class="bi bi-pencil-square me-2"></i>Edit Department</h1>
    <p>Update details for <strong>@Model.Name</strong></p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card ls-card">
            <div class="card-body p-4">
                <form asp-action="Edit" id="editDeptForm" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">
                            <i class="bi bi-building me-1 text-warning"></i>Department Name
                        </label>
                        <input asp-for="Name" class="form-control" id="inp_Name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="MgrName" class="form-label">
                            <i class="bi bi-person-check me-1 text-warning"></i>Manager Name
                        </label>
                        <input asp-for="MgrName" class="form-control" id="inp_Mgr" />
                        <span asp-validation-for="MgrName" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4">
                            <i class="bi bi-save me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function(){
            const form=document.getElementById('editDeptForm'),name=document.getElementById('inp_Name'),mgr=document.getElementById('inp_Mgr');
            const se=(el,m)=>{el.classList.add('is-invalid');const s=el.nextElementSibling;if(s&&s.tagName==='SPAN')s.textContent=m;return false;};
            const ce=(el)=>{el.classList.remove('is-invalid');el.classList.add('is-valid');const s=el.nextElementSibling;if(s&&s.tagName==='SPAN')s.textContent='';return true;};
            const vN=()=>{const v=name.value.trim();if(!v)return se(name,'Required.');if(!/^[a-zA-Z\s]+$/.test(v))return se(name,'Letters only.');return ce(name);};
            const vM=()=>{const v=mgr.value.trim();if(!v)return se(mgr,'Required.');if(!/^[a-zA-Z\s.]+$/.test(v))return se(mgr,'Letters only.');return ce(mgr);};
            name.addEventListener('input',vN);mgr.addEventListener('input',vM);
            form.addEventListener('submit',e=>{if(!(vN()&vM()))e.preventDefault();});
        })();
    </script>
}
