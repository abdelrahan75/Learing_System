@model Task_Day_2_ASP.Models.Entities.Department
@{
    ViewData["Title"] = "Department Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#f59e0b,#d97706)">
    <h1><i class="bi bi-building-fill me-2"></i>Department Details</h1>
    <p><strong>@Model.Name</strong></p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card ls-card">
            <div class="card-header d-flex align-items-center gap-3"
                 style="background:linear-gradient(135deg,#f59e0b,#d97706);color:white;">
                <span style="font-size:2rem;">🏢</span>
                <div>
                    <div class="fw-bold fs-5">@Model.Name</div>
                    <div class="opacity-75 small">ID: #@Model.Id</div>
                </div>
            </div>
            <div class="card-body p-4">
                <dl class="row ls-detail-row g-3">
                    <dt class="col-sm-4">Department</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Name</dd>
                    <dt class="col-sm-4">Manager</dt>
                    <dd class="col-sm-8">
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:#fef3c7;color:#92400e;font-weight:600">
                            @Model.MgrName
                        </span>
                    </dd>
                    @if (Model.Students?.Any() == true)
                    {
                        <dt class="col-sm-4">Students</dt>
                        <dd class="col-sm-8"><span class="badge bg-info text-white rounded-pill">@Model.Students.Count</span></dd>
                    }
                    @if (Model.Teachers?.Any() == true)
                    {
                        <dt class="col-sm-4">Teachers</dt>
                        <dd class="col-sm-8"><span class="badge rounded-pill" style="background:#ede9fe;color:#6d28d9;">@Model.Teachers.Count</span></dd>
                    }
                    @if (Model.Courses?.Any() == true)
                    {
                        <dt class="col-sm-4">Courses</dt>
                        <dd class="col-sm-8"><span class="badge bg-success text-white rounded-pill">@Model.Courses.Count</span></dd>
                    }
                </dl>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2 p-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i> Edit</a>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
            </div>
        </div>
    </div>
</div>
