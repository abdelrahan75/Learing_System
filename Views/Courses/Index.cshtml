@model IEnumerable<Task_Day_2_ASP.Models.Entities.Course>
@{
    ViewData["Title"] = "Courses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#10b981,#059669)">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1><i class="bi bi-journal-bookmark me-2"></i>Courses</h1>
            <p>Total: <strong>@Model.Count()</strong> active courses</p>
        </div>
        <a asp-action="Create" class="btn fw-bold px-4"
           style="background:rgba(255,255,255,0.95);color:#059669;">
            <i class="bi bi-plus-circle me-1"></i> Add Course
        </a>
    </div>
</div>

<div class="card ls-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table ls-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th><i class="bi bi-bookmark me-1"></i>Course Name</th>
                        <th><i class="bi bi-bar-chart me-1"></i>Max Degree</th>
                        <th><i class="bi bi-check-circle me-1"></i>Min Pass</th>
                        <th><i class="bi bi-building me-1"></i>Department</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;">@(i++)</span></td>
                            <td class="fw-500">@item.Name</td>
                            <td>
                                <span class="badge bg-primary rounded-pill px-3">@item.Degree</span>
                            </td>
                            <td>
                                <span class="badge rounded-pill px-3"
                                      style="background:#fef3c7;color:#92400e;font-weight:600">
                                    @item.MinDegree
                                </span>
                            </td>
                            <td>
                                @if (item.Departments != null)
                                {
                                    <span class="text-muted small">@item.Departments.Name</span>
                                }
                                else
                                {

                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:0.5rem;"></i>
                                No courses found. <a asp-action="Create">Add the first course.</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
