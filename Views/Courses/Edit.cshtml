@model Task_Day_2_ASP.Models.Entities.Course
@{
    ViewData["Title"] = "Edit Course";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#f59e0b,#d97706)">
    <h1><i class="bi bi-pencil-square me-2"></i>Edit Course</h1>
    <p>Update details for <strong>@Model.Name</strong></p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card ls-card">
            <div class="card-body p-4">
                <form asp-action="Edit" id="editCourseForm" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"><i class="bi bi-bookmark me-1 text-warning"></i>Course Name</label>
                        <input asp-for="Name" class="form-control" id="inp_Name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="Degree" class="form-label">Max Degree</label>
                            <input asp-for="Degree" class="form-control" id="inp_Deg" type="number" min="0" max="100" />
                            <span asp-validation-for="Degree" class="text-danger small"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="MinDegree" class="form-label">Min Pass</label>
                            <input asp-for="MinDegree" class="form-control" id="inp_Min" type="number" min="0" max="100" />
                            <span asp-validation-for="MinDegree" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="DepartmentId" class="form-label"><i class="bi bi-building me-1 text-warning"></i>Department</label>
                        <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId" id="inp_Dept">
                            <option value="">— Select Department —</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4"><i class="bi bi-save me-1"></i> Save Changes</button>
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function(){
            const form=document.getElementById('editCourseForm'),name=document.getElementById('inp_Name'),deg=document.getElementById('inp_Deg'),min=document.getElementById('inp_Min'),dept=document.getElementById('inp_Dept');
            const se=(el,m)=>{el.classList.add('is-invalid');const s=el.nextElementSibling;if(s&&s.tagName==='SPAN')s.textContent=m;return false;};
            const ce=(el)=>{el.classList.remove('is-invalid');el.classList.add('is-valid');const s=el.nextElementSibling;if(s&&s.tagName==='SPAN')s.textContent='';return true;};
            const vN=()=>{const v=name.value.trim();if(!v)return se(name,'Required.');if(!/^[a-zA-Z\s]+$/.test(v))return se(name,'Letters only.');return ce(name);};
            const vD=()=>{const v=parseInt(deg.value);if(deg.value===''||isNaN(v)||v<0||v>100)return se(deg,'0–100.');return ce(deg);};
            const vM=()=>{const vd=parseInt(deg.value),vm=parseInt(min.value);if(min.value===''||isNaN(vm)||vm<0||vm>100)return se(min,'0–100.');if(!isNaN(vd)&&vm>vd)return se(min,'Min ≤ Max.');return ce(min);};
            const vDp=()=>{if(!dept.value)return se(dept,'Required.');return ce(dept);};
            name.addEventListener('input',vN);deg.addEventListener('input',vD);min.addEventListener('input',vM);dept.addEventListener('change',vDp);
            form.addEventListener('submit',e=>{if(!(vN()&vD()&vM()&vDp()))e.preventDefault();});
        })();
    </script>
}
