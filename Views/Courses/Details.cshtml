@model Task_Day_2_ASP.Models.Entities.Course
@{
    ViewData["Title"] = "Course Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#10b981,#059669)">
    <h1><i class="bi bi-journal-text me-2"></i>Course Details</h1>
    <p><strong>@Model.Name</strong></p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card ls-card">
            <div class="card-header d-flex align-items-center gap-3"
                 style="background:linear-gradient(135deg,#10b981,#059669);color:white;">
                <span style="font-size:2rem;">📚</span>
                <div>
                    <div class="fw-bold fs-5">@Model.Name</div>
                    <div class="opacity-75 small">Course ID: #@Model.Id</div>
                </div>
            </div>
            <div class="card-body p-4">
                <dl class="row ls-detail-row g-3">
                    <dt class="col-sm-5">Max Degree</dt>
                    <dd class="col-sm-7"><span class="badge bg-primary rounded-pill px-3">@Model.Degree</span></dd>
                    <dt class="col-sm-5">Min Pass Degree</dt>
                    <dd class="col-sm-7">
                        <span class="badge rounded-pill px-3" style="background:#fef3c7;color:#92400e;font-weight:600">
                            @Model.MinDegree
                        </span>
                    </dd>
                    <dt class="col-sm-5">Department Manager</dt>
                    <dd class="col-sm-7 text-muted">@(Model.Departments?.MgrName ?? "—")</dd>
                    <dt class="col-sm-5">Department</dt>
                    <dd class="col-sm-7">@(Model.Departments?.Name ?? "—")</dd>
                </dl>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2 p-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i> Edit</a>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
            </div>
        </div>
    </div>
</div>
