@model Task_Day_2_ASP.Models.Entities.Course
@{
    ViewData["Title"] = "Delete Course";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#ef4444,#b91c1c)">
    <h1><i class="bi bi-journal-x me-2"></i>Delete Course</h1>
    <p>This action cannot be undone.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card ls-card delete-card">
            <div class="card-body p-4">
                <div class="alert alert-danger rounded-3 d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <span>Are you sure you want to permanently delete course <strong>@Model.Name</strong>?</span>
                </div>
                <dl class="row ls-detail-row g-3">
                    <dt class="col-sm-5">Course Name</dt>
                    <dd class="col-sm-7 fw-bold">@Model.Name</dd>
                    <dt class="col-sm-5">Max Degree</dt>
                    <dd class="col-sm-7">@Model.Degree</dd>
                    <dt class="col-sm-5">Min Pass</dt>
                    <dd class="col-sm-7">@Model.MinDegree</dd>
                    <dt class="col-sm-5">Department Manager</dt>
                    <dd class="col-sm-7">@(Model.Departments?.MgrName ?? "—")</dd>
                </dl>
                <hr />
                <form asp-action="Delete" class="d-flex gap-2 mt-3">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger px-4"><i class="bi bi-trash me-1"></i> Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-circle me-1"></i> Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
