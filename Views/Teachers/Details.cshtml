@model Task_Day_2_ASP.Models.Entities.Teacher
@{
    ViewData["Title"] = "Teacher Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed)">
    <h1><i class="bi bi-person-lines-fill me-2"></i>Teacher Details</h1>
    <p>Profile for <strong>@Model.Name</strong></p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card ls-card">
            <div class="card-header d-flex align-items-center gap-3"
                 style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);color:white;">
                <span style="font-size:2rem;">👩‍🏫</span>
                <div>
                    <div class="fw-bold fs-5">@Model.Name</div>
                    <div class="opacity-75 small">ID: #@Model.Id</div>
                </div>
            </div>
            <div class="card-body p-4">
                <dl class="row ls-detail-row g-3">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Name</dd>
                    <dt class="col-sm-4">Salary</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-success text-white rounded-pill px-3">@Model.Salary.ToString("C")</span>
                    </dd>
                    <dt class="col-sm-4">Department</dt>
                    <dd class="col-sm-8">
                        @if (Model.Department != null)
                        {
                            <span class="badge rounded-pill px-3 py-1"
                                  style="background:#fef3c7;color:#92400e;font-weight:600">
                                @Model.Department.Name
                            </span>
                        }
                        else
                        {

                            <span class="text-muted">—</span>
                        }
                    </dd>
                    <dt class="col-sm-4">Course</dt>
                    <dd class="col-sm-8">
                        @if (Model.Course != null)
                        {
                            <span class="badge rounded-pill px-3 py-1"
                                  style="background:#d1fae5;color:#065f46;font-weight:600">
                                @Model.Course.Name
                            </span>
                        }
                        else
                        {

                            <span class="text-muted">—</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2 p-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i> Edit
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>
    </div>
</div>
