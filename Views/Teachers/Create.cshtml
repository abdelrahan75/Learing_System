@model Task_Day_2_ASP.Models.Entities.Teacher
@{
    ViewData["Title"] = "Add Teacher";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed)">
    <h1><i class="bi bi-person-plus me-2"></i>Add New Teacher</h1>
    <p>Fill in the details to add a new staff member.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card ls-card">
            <div class="card-body p-4">
                <form asp-action="Create" id="createTeacherForm" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">
                            <i class="bi bi-person me-1" style="color:#8b5cf6"></i>Teacher Name
                        </label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Dr. Sarah Ahmed" id="inp_Name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Salary" class="form-label">
                            <i class="bi bi-currency-dollar me-1" style="color:#8b5cf6"></i>Salary
                        </label>
                        <input asp-for="Salary" class="form-control" placeholder="e.g. 5000.00" id="inp_Salary" type="number" min="0" max="999999" step="0.01" />
                        <span asp-validation-for="Salary" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DepartmentId" class="form-label">
                            <i class="bi bi-building me-1" style="color:#8b5cf6"></i>Department
                        </label>
                        <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId" id="inp_Dept">
                            <option value="">— Select Department —</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CourseId" class="form-label">
                            <i class="bi bi-journal-bookmark me-1" style="color:#8b5cf6"></i>Course
                        </label>
                        <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId" id="inp_Course">
                            <option value="">— Select Course —</option>
                        </select>
                        <span asp-validation-for="CourseId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn px-4" style="background:#8b5cf6;color:white;">
                            <i class="bi bi-save me-1"></i> Save Teacher
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function () {
            const form   = document.getElementById('createTeacherForm');
            const name   = document.getElementById('inp_Name');
            const salary = document.getElementById('inp_Salary');
            const dept   = document.getElementById('inp_Dept');

            function setError(el, msg) {
                el.classList.add('is-invalid'); el.classList.remove('is-valid');
                const s = el.nextElementSibling;
                if (s && s.tagName === 'SPAN') s.textContent = msg;
                return false;
            }
            function clearError(el) {
                el.classList.remove('is-invalid'); el.classList.add('is-valid');
                const s = el.nextElementSibling;
                if (s && s.tagName === 'SPAN') s.textContent = '';
                return true;
            }
            const vName = () => {
                const v = name.value.trim();
                if (!v) return setError(name, 'Name is required.');
                if (v.length < 2 || v.length > 50) return setError(name, 'Name must be 2–50 characters.');
                if (!/^[a-zA-Z\s.]+$/.test(v)) return setError(name, 'Letters, spaces and dots only.');
                return clearError(name);
            };
            const vSalary = () => {
                const v = parseFloat(salary.value);
                if (salary.value === '') return setError(salary, 'Salary is required.');
                if (isNaN(v) || v < 0 || v > 999999) return setError(salary, 'Salary must be 0–999,999.');
                return clearError(salary);
            };
            const vDept = () => {
                if (!dept.value) return setError(dept, 'Please select a department.');
                return clearError(dept);
            };
            name.addEventListener('input', vName);
            salary.addEventListener('input', vSalary);
            dept.addEventListener('change', vDept);
            form.addEventListener('submit', e => { if (!(vName() & vSalary() & vDept())) e.preventDefault(); });
        })();
    </script>
}
