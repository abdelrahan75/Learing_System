@using Task_Day_2_ASP.Models.Entities
@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#ef4444,#b91c1c)">
    <h1><i class="bi bi-exclamation-octagon me-2"></i>Oops! Something went wrong.</h1>
    <p>An error occurred while processing your request.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card ls-card">
            <div class="card-body p-4 text-center">
                <div style="font-size:5rem;">⚠️</div>
                <h4 class="mt-3 fw-bold text-danger">Unexpected Error</h4>
                <p class="text-muted">The application encountered an unexpected error. Please try again or contact support.</p>

                @if (Model.ShowRequestId)
                {
                    <div class="alert alert-secondary rounded-3 text-start mt-3">
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    </div>
                }

                <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3 px-5">
                    <i class="bi bi-house me-1"></i> Go to Home
                </a>
            </div>
        </div>
    </div>
</div>
