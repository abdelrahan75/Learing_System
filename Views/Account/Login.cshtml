@using Task_Day_2_ASP.Models.ViewModel
@model ViewModelLogin

@{
    ViewData["Title"] = "Login";
}

<div class="page-header" style="background:linear-gradient(135deg,#10b981,#059669)">
    <div class="text-center">
        <h1><i class="bi bi-box-arrow-in-right me-2"></i>Login</h1>
        <p>Sign in to access the Learning System</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card ls-card">
            <div class="card-body p-4">
                <form asp-action="Login" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label">
                            <i class="bi bi-person me-1 text-primary"></i>Username
                        </label>
                        <input asp-for="UserName" class="form-control" placeholder="Enter your username" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label">
                            <i class="bi bi-lock me-1 text-primary"></i>Password
                        </label>
                        <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Login
                        </button>
                        <a asp-action="Register" class="btn btn-secondary">
                            <i class="bi bi-person-plus me-1"></i> Register
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
