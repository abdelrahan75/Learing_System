@model Task_Day_2_ASP.Models.Entities.Student

@{
    ViewData["Title"] = "Edit Student";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header" style="background:linear-gradient(135deg,#f59e0b,#d97706)">
    <h1><i class="bi bi-pencil-square me-2"></i>Edit Student</h1>
    <p>Update the details for <strong>@Model.Name</strong>.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card ls-card">
            <div class="card-body p-4">
                <form asp-action="Edit" id="editStudentForm" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">
                            <i class="bi bi-person me-1 text-warning"></i>Student Name
                        </label>
                        <input asp-for="Name" class="form-control" id="inp_Name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Age" class="form-label">
                            <i class="bi bi-calendar me-1 text-warning"></i>Age
                        </label>
                        <input asp-for="Age" class="form-control" id="inp_Age" type="number" min="5" max="100" />
                        <span asp-validation-for="Age" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DepartmentId" class="form-label">
                            <i class="bi bi-building me-1 text-warning"></i>Department
                        </label>
                        <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId" id="inp_Dept">
                            <option value="">— Select Department —</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4">
                            <i class="bi bi-save me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function () {
            const form = document.getElementById('editStudentForm');
            const name = document.getElementById('inp_Name');
            const age  = document.getElementById('inp_Age');
            const dept = document.getElementById('inp_Dept');

            function setError(el, msg) {
                el.classList.add('is-invalid'); el.classList.remove('is-valid');
                const s = el.nextElementSibling;
                if (s && s.tagName === 'SPAN') s.textContent = msg;
                return false;
            }
            function clearError(el) {
                el.classList.remove('is-invalid'); el.classList.add('is-valid');
                const s = el.nextElementSibling;
                if (s && s.tagName === 'SPAN') s.textContent = '';
                return true;
            }
            const validateName = () => {
                const v = name.value.trim();
                if (!v) return setError(name, 'Name is required.');
                if (v.length < 2 || v.length > 50) return setError(name, 'Name must be 2–50 characters.');
                if (!/^[a-zA-Z\s]+$/.test(v)) return setError(name, 'Letters and spaces only.');
                return clearError(name);
            };
            const validateAge = () => {
                const v = parseInt(age.value);
                if (!age.value) return setError(age, 'Age is required.');
                if (isNaN(v) || v < 5 || v > 100) return setError(age, 'Age must be 5–100.');
                return clearError(age);
            };
            const validateDept = () => {
                if (!dept.value) return setError(dept, 'Please select a department.');
                return clearError(dept);
            };

            name.addEventListener('input', validateName);
            age.addEventListener('input', validateAge);
            dept.addEventListener('change', validateDept);
            form.addEventListener('submit', e => { if (!(validateName() & validateAge() & validateDept())) e.preventDefault(); });
        })();
    </script>
}
