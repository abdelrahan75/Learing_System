</div>

<div class="row">
    <div class="col-12">
        <div class="card ls-card mb-4">
            <div class="card-header bg-primary text-white">
                <i class="bi bi-people"></i> Students Controller
            </div>
            <div class="card-body p-0">
                <table class="table ls-table mb-0">
                    <thead>
                        <tr>
                            <th style="width: 120px;">Method</th>
                            <th style="width: 250px;">Endpoint</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge bg-success">GET</span></td>
                            <td><code>/Students</code></td>
                            <td>List all students</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-success">GET</span></td>
                            <td><code>/Students/Details/{id}</code></td>
                            <td>Get student details by ID</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-success">GET</span></td>
                            <td><code>/Students/DetailsOfVM/{id}</code></td>
                            <td>Get student details as ViewModel</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-primary">GET</span></td>
                            <td><code>/Students/Create</code></td>
                            <td>Show create student form</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-warning">POST</span></td>
                            <td><code>/Students/Create</code></td>
                            <td>Create new student</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-primary">GET</span></td>
                            <td><code>/Students/Edit/{id}</code></td>
                            <td>Show edit student form</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-warning">POST</span></td>
                            <td><code>/Students/Edit/{id}</code></td>
                            <td>Update student</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-primary">GET</span></td>
                            <td><code>/Students/Delete/{id}</code></td>
                            <td>Show delete confirmation</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-warning">POST</span></td>
                            <td><code>/Students/Delete</code></td>
                            <td>Delete student</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-success">GET</span></td>
                            <td><code>/Students/ShowResult</code></td>
                            <td>Show student course result (params: StuId, CrsId)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

